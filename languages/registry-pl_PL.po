#. Plugin Name of the plugin
#: registry.php
msgid "Registry - Gift Registry for WooCommerce"
msgstr "Registry - Lista prezentów dla WooCommerce"

#. Plugin URI of the plugin
#: registry.php
msgid "https://plogins.com/registry/"
msgstr "https://plogins.com/registry/"

#. Description of the plugin
#: registry.php
msgid ""
"Let customers create shareable gift registries for weddings, baby showers "
"and events."
msgstr ""
"Pozwól klientom tworzyć udostępniane listy prezentów na śluby, baby shower i "
"inne wydarzenia."

#. Author of the plugin
#: registry.php
msgid "WPPoland"
msgstr "WPPoland"

